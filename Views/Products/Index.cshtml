@model IEnumerable<Mini_Store.Models.Product>

@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container py-5" dir="rtl">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="dashboard-title mb-2">إدارة المنتجات</h2>
            <p class="page-description mb-0">
                إدارة المنتجات وإضافة وتعديل وحذف البيانات.
            </p>
        </div>
<form asp-action="Index" method="get"
      class="d-flex align-items-center gap-3 mb-4">

    <input type="text"
           name="searchString"
           value="@ViewBag.SearchString"
           class="form-control search-input"
           placeholder="ابحث عن منتج..." />

    <button type="submit" class="btn btn-search px-4">
        بحث
    </button>

    <a asp-action="Index" class="btn btn-reset px-4">
        عرض الكل
    </a>

</form>
        <a asp-action="Create" class="btn btn-primary px-4">
            إضافة منتج
        </a>

    </div>

    <div class="card dashboard-card">

        <div class="dashboard-header d-flex justify-content-between align-items-center">

            <h5 class="mb-0">
                قائمة المنتجات
            </h5>

            <span class="badge bg-light text-dark fs-6">
                @Model.Count() منتج
            </span>

        </div>

        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0 dashboard-table">

                <thead>

                    <tr>

                        <th>#</th>
                        <th>الصورة</th>
                        <th>اسم المنتج</th>
                        <th>الفئة</th>
                        <th>السعر</th>
                        <th class="text-center">الإجراءات</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.Id</td>

                                <td>
                                    <img src="~/Images/@item.Image"
                                         class="product-image" />
                                </td>

                                <td class="fw-semibold">
                                    @item.Name
                                </td>

                                <td>
                                    @item.Category?.Name
                                </td>

                                <td class="text-success fw-bold">
                                    @item.Price ر.س
                                </td>

                                <td class="text-center">

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning me-1">

                                        تعديل

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger">

                                        حذف

                                    </a>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="6" class="text-center py-5 text-muted">

                                لا توجد منتجات حالياً.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>