@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.AspNetCore.Identity

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject IHtmlLocalizer<SharedResource> SharedLocalizer


@{
    var isRTL = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDir = isRTL ? "rtl" : "ltr";
    var htmlLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
}


<!DOCTYPE html>

<html lang="@htmlLang" dir="@htmlDir">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Mini Store</title>

    <script type="importmap"></script>

    @if (isRTL)
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
    <link rel="stylesheet"
      href="~/css/account.css"
      asp-append-version="true" />

    <link rel="stylesheet"
          href="~/Mini_Store.styles.css"
          asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm sticky-top">

        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">

                <i class="fa-solid fa-store"></i>

                @SharedLocalizer["StoreSystem"]

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbar">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbar">

                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Index">

                            @SharedLocalizer["Home"]

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="About">

                            @SharedLocalizer["About"]

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Contact">

                            @SharedLocalizer["Contact"]

                        </a>
                    </li>

                </ul>

                <div class="d-flex align-items-center gap-3">

                    <form class="search-box d-flex"
                          asp-controller="Home"
                          asp-action="Search"
                          method="get">

                        <input class="form-control"
                               type="search"
                               name="keyword"
                               placeholder="@SharedLocalizer["SearchPlaceholder"]" />

                        <button type="submit" class="btn btn-warning">

                            <i class="fa-solid fa-magnifying-glass"></i>

                        </button>

                    </form>

                    <a href="#" class="cart-icon">

                        <i class="fa-solid fa-cart-shopping"></i>

                    </a>
                 <div class="dropdown">

    <button class="language-btn dropdown-toggle"
        type="button"
        data-bs-toggle="dropdown"
        aria-expanded="false">

    <i class="fa-solid fa-language"></i>

    @(isRTL ? "العربية" : "English")

</button>

    <ul class="dropdown-menu dropdown-menu-end">

        <li>

            <a class="dropdown-item"
               asp-controller="Culture"
               asp-action="SetLanguage"
               asp-route-culture="ar"
               asp-route-returnUrl="@Context.Request.Path">

                 العربية

            </a>

        </li>

        <li>

            <a class="dropdown-item"
               asp-controller="Culture"
               asp-action="SetLanguage"
               asp-route-culture="en-US"
               asp-route-returnUrl="@Context.Request.Path">

                 English

            </a>

        </li>

    </ul>

</div>
                </div>

            </div>
<div class="dropdown user-dropdown">

    <button class="btn btn-outline-light dropdown-toggle d-flex align-items-center gap-2"
            data-bs-toggle="dropdown">

        <i class="fa-regular fa-circle-user fs-5"></i>

        @if (SignInManager.IsSignedIn(User))
        {
            @UserManager.GetUserName(User)
        }
        else
        {
            <span>الحساب</span>
        }

    </button>

    <ul class="dropdown-menu dropdown-menu-end">

        @if (SignInManager.IsSignedIn(User))
        {
            <li>
                <h6 class="dropdown-header">
                    @UserManager.GetUserName(User)
                </h6>
            </li>

            <li>
                <a class="dropdown-item" href="#">
                    <i class="fa-regular fa-user me-2"></i>
                    الملف الشخصي
                </a>
            </li>

            <li>
                <a class="dropdown-item" href="#">
                    <i class="fa-solid fa-gear me-2"></i>
                    الإعدادات
                </a>
            </li>

            <li>
                @if (User.IsInRole("Admin"))
{
    <a asp-controller="Products"
       asp-action="Index"
       class="dropdown-item">

        لوحة التحكم

    </a>
}
            </li>

            <li><hr class="dropdown-divider"></li>

            <li>
                <form asp-controller="Account"
                      asp-action="Logout"
                      method="post">

                    <button type="submit"
                            class="dropdown-item text-danger">

                        <i class="fa-solid fa-right-from-bracket me-2"></i>

                        تسجيل الخروج

                    </button>

                </form>
            </li>
        }
        else
        {
            <li>
                <a class="dropdown-item"
                   asp-controller="Account"
                   asp-action="Login">

                    <i class="fa-solid fa-right-to-bracket me-2"></i>

                    تسجيل الدخول

                </a>
            </li>

            <li>
                <a class="dropdown-item"
                   asp-controller="Account"
                   asp-action="Register">

                    <i class="fa-solid fa-user-plus me-2"></i>

                    إنشاء حساب

                </a>
            </li>
        }

    </ul>

</div>
        </div>

    </nav>

    <main  class="container-fluid p-0 flex-grow-1">
        @RenderBody()
    </main>

    <!-- Footer -->

    <footer class="footer mt-5">

        <div class="container">

            <div class="row gy-4">

                <div class="col-lg-4">

                    <h4>@SharedLocalizer["StoreSystem"]</h4>

                    <p>

                        @SharedLocalizer["FooterDescription"]

                    </p>

                    <div class="social">

                        <i class="fab fa-facebook"></i>
                        <i class="fab fa-twitter"></i>
                        <i class="fab fa-instagram"></i>
                        <i class="fab fa-linkedin"></i>

                    </div>

                </div>

                <div class="col-lg-4">

                    <h5>@SharedLocalizer["QuickLinks"]</h5>

                    <ul class="list-unstyled">

                        <li>

                            <a asp-controller="Home"
                               asp-action="Index">

                                @SharedLocalizer["Home"]

                            </a>

                        </li>

                        <li>

                            <a asp-controller="Home"
                               asp-action="About">

                                @SharedLocalizer["About"]

                            </a>

                        </li>

                        <li>

                            <a asp-controller="Home"
                               asp-action="Contact">

                                @SharedLocalizer["Contact"]

                            </a>

                        </li>

                    </ul>

                </div>

                <div class="col-lg-4">

                    <h5>@SharedLocalizer["ContactUs"]</h5>

                    <p>

                        info@ministore.com

                        <br />

                        +966 500000000

                    </p>

                </div>

            </div>

            <hr />

            <p class="text-center mb-0">

                © 2026 @SharedLocalizer["StoreSystem"] -
                @SharedLocalizer["AllRightsReserved"]

            </p>

        </div>

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>